@page "/settings"
@inject IStatsApiStreamService StatsApiStreamService
@inject IRocketLeagueConfigService ConfigService
@inject IToastService ToastService

<section class="page-header">
  <div>
    <p class="eyebrow">Preferences</p>
    <h1>Settings</h1>
    <p>Pick your player and configure Rocket League's local Stats API.</p>
  </div>
</section>

<section class="card">
  <div class="section-title">
    <h2>You</h2>
    <span class="muted">Used to compute streaks and head-to-head from your perspective</span>
  </div>

  @if (_observed.Count == 0)
  {
    <p class="muted">No players have been observed yet. Start a Rocket League match or replay so the listener can see you.</p>
  }
  else
  {
    <div class="form-grid form-grid-me">
      <label>
        <span>Pick your player</span>
        <select class="input" @bind="_selectedMeId">
          <option value="">— Not set —</option>
          @foreach (var player in _observed)
          {
            <option value="@player.PrimaryId">@player.Name</option>
          }
        </select>
      </label>
      <button class="primary-button accent-positive" @onclick="SaveMeAsync">Save</button>
      @if (_currentMe is not null)
      {
        <button class="link-button accent-danger" @onclick="ClearMeAsync">Clear</button>
      }
    </div>

    @if (_currentMe is not null)
    {
      <p class="muted me-status">
        Current me:
        <span class="chip chip-me">@_currentMe.Name</span>
      </p>
    }
  }
</section>

<section class="card">
  <div class="section-title">
    <h2>Rocket League Stats API config</h2>
    <span class="muted">Edits <code>DefaultStatsAPI.ini</code></span>
  </div>

  <p class="muted">
    Set <strong>PacketSendRate</strong> &gt; 0 to enable the local socket. The default port is <code>49123</code>.
    Writing into <code>Program Files</code> usually requires running Rocket Stats as administrator.
  </p>

  <div class="form-grid form-grid-config">
    <label class="path-label">
      <span>Path to DefaultStatsAPI.ini</span>
      <input class="input" type="text" @bind="_path" placeholder="C:\Program Files (x86)\Steam\steamapps\common\rocketleague\TAGame\Config\DefaultStatsAPI.ini" />
    </label>
    <label>
      <span>PacketSendRate</span>
      <input class="input" type="number" min="0" max="120" step="1" @bind="_packetSendRate" />
    </label>
    <label>
      <span>Port</span>
      <input class="input" type="number" min="1" max="65535" step="1" @bind="_port" />
    </label>
    <div class="config-actions">
      <button class="link-button" @onclick="ReloadAsync">Reload</button>
      <button class="primary-button accent-positive" @onclick="SaveConfigAsync">Save .ini</button>
    </div>
  </div>

  @if (_candidatePaths.Count > 0)
  {
    <div class="muted candidate-paths">
      <span>Detected:</span>
      @foreach (var candidate in _candidatePaths)
      {
        <button type="button" class="link-button candidate-chip" @onclick="() => UseCandidate(candidate)">@candidate</button>
      }
    </div>
  }

  @if (_config is not null)
  {
    <div class="config-status">
      @if (_config.Exists)
      {
        <span class="chip chip-up">File exists</span>
        @if (_config.Writable)
        {
          <span class="chip chip-up">Writable</span>
        }
        else
        {
          <span class="chip chip-down">Read-only / needs admin</span>
        }
      }
      else
      {
        <span class="chip chip-down">File not found</span>
      }
    </div>
  }

  @if (!string.IsNullOrWhiteSpace(_writeError))
  {
    <section class="alert">@_writeError</section>
  }
</section>

@code {
  private IReadOnlyList<ObservedPlayer> _observed = [];
  private ObservedPlayer? _currentMe;
  private string _selectedMeId = string.Empty;

  private RocketLeagueStatsApiConfig? _config;
  private IReadOnlyList<string> _candidatePaths = [];
  private string _path = string.Empty;
  private double _packetSendRate = 30;
  private int _port = 49123;
  private string? _writeError;

  protected override async Task OnInitializedAsync()
  {
    await RefreshObservedAsync();
    await ReloadAsync();
  }

  private async Task RefreshObservedAsync()
  {
    _observed = await StatsApiStreamService.GetObservedPlayersAsync();
    _currentMe = _observed.FirstOrDefault(player => player.IsMe);
    _selectedMeId = _currentMe?.PrimaryId ?? string.Empty;
  }

  private async Task SaveMeAsync()
  {
    var primaryId = string.IsNullOrWhiteSpace(_selectedMeId) ? null : _selectedMeId;
    await StatsApiStreamService.SetMeAsync(primaryId);
    ToastService.Show(primaryId is null ? "Cleared 'me' player." : "Saved 'me' player.");
    await RefreshObservedAsync();
  }

  private async Task ClearMeAsync()
  {
    await StatsApiStreamService.SetMeAsync(null);
    ToastService.Show("Cleared 'me' player.");
    await RefreshObservedAsync();
  }

  private async Task ReloadAsync()
  {
    _writeError = null;
    _candidatePaths = ConfigService.GetCandidatePaths();
    _config = await ConfigService.ReadAsync();

    if (_config is not null)
    {
      _path = _config.Path;

      if (_config.Exists)
      {
        _packetSendRate = _config.PacketSendRate > 0 ? _config.PacketSendRate : _packetSendRate;
        _port = _config.Port > 0 ? _config.Port : _port;
      }
    }
  }

  private void UseCandidate(string candidate)
  {
    _path = candidate;
  }

  private async Task SaveConfigAsync()
  {
    _writeError = null;

    if (string.IsNullOrWhiteSpace(_path))
    {
      _writeError = "Provide a path to DefaultStatsAPI.ini.";
      return;
    }

    var result = await ConfigService.WriteAsync(_path, _packetSendRate, _port);

    if (!result.Success)
    {
      _writeError = result.Error;
      ToastService.Show("Failed to save .ini file.");
      return;
    }

    await ConfigService.SetSavedPathAsync(_path);
    ToastService.Show("Saved .ini. Restart Rocket League to apply.");
    _config = await ConfigService.ReadAsync(_path);
  }
}
