@page "/connection"
@implements IDisposable
@inject IStatsApiStreamService StatsApiStreamService
@inject IToastService ToastService

<section class="page-header">
  <div>
    <p class="eyebrow">Local Stats API</p>
    <h1>Connection</h1>
    <p>Control the listener and inspect raw events coming off Rocket League's local WebSocket.</p>
  </div>
  <div class="actions">
    <button class="link-button" @onclick="RefreshClickedAsync">Refresh</button>
    @if (StatsApiStreamService.ConnectionState == StatsApiConnectionState.Connected)
    {
      <button class="secondary-button" @onclick="StopAsync">Stop</button>
    }
    else if (StatsApiStreamService.ConnectionState == StatsApiConnectionState.Connecting)
    {
      <button class="primary-button" disabled>Starting...</button>
    }
    else
    {
      <button class="primary-button" @onclick="StartAsync">Start listener</button>
    }
  </div>
</section>

<section class="grid">
  <StatsSummaryCard Title="Connection" Value="@StatsApiStreamService.ConnectionState.ToString()" Detail="@_connectionDetail" />
  <StatsSummaryCard Title="Observed Players" Value="@_observedPlayerCount.ToString()" Detail="Collected from UpdateState" />
  <StatsSummaryCard Title="Tracked Players" Value="@_dashboardPlayerCount.ToString()" Detail="Enabled on Players screen" />
  <StatsSummaryCard Title="Logged Events" Value="@_events.Count.ToString()" Detail="Stored locally" />
</section>

@if (!string.IsNullOrWhiteSpace(StatsApiStreamService.LastError))
{
  <section class="alert">@StatsApiStreamService.LastError</section>
}

<section class="card">
  <div class="section-title">
    <h2>Recent events</h2>
    <span class="muted">Latest 10</span>
  </div>

  @if (_events.Count == 0)
  {
    <p class="muted">No Stats API messages have been logged yet.</p>
  }
  else
  {
    <div class="match-list">
      @foreach (var entry in _events.Take(10))
      {
        <article class="match-row">
          <div>
            <strong>@entry.EventName</strong>
            <span>@(entry.MatchGuid ?? "No match id")</span>
          </div>
          <span>@entry.ReceivedAt.LocalDateTime.ToString("T")</span>
        </article>
      }
    </div>
  }
</section>

<section class="card">
  <h2>Setup reminder</h2>
  <p class="muted">
    Rocket League must be restarted after enabling the Stats API. Set <code>PacketSendRate</code> above 0 in
    <code>TAGame\Config\DefaultStatsAPI.ini</code>. The default socket port is <code>49123</code>.
  </p>
</section>

@code {
  private readonly PeriodicTimer _refreshTimer = new(TimeSpan.FromSeconds(2));

  private IReadOnlyList<StatsApiEventLogEntry> _events = [];
  private int _observedPlayerCount;
  private int _dashboardPlayerCount;
  private string _connectionDetail = "ws://localhost:49123";

  protected override async Task OnInitializedAsync()
  {
    await RefreshAsync();
    _ = RefreshLoopAsync();
  }

  public void Dispose()
  {
    _refreshTimer.Dispose();
  }

  private async Task StartAsync()
  {
    await StatsApiStreamService.StartAsync();
    ToastService.Show("Listener starting.");
    await RefreshAsync();
  }

  private async Task StopAsync()
  {
    await StatsApiStreamService.StopAsync();
    ToastService.Show("Listener stopped.");
    await RefreshAsync();
  }

  private async Task RefreshClickedAsync()
  {
    await RefreshAsync();
    ToastService.Show("Connection refreshed.");
  }

  private async Task RefreshLoopAsync()
  {
    while (await _refreshTimer.WaitForNextTickAsync())
    {
      await InvokeAsync(async () =>
      {
        await RefreshAsync();
        StateHasChanged();
      });
    }
  }

  private async Task RefreshAsync()
  {
    _events = await StatsApiStreamService.GetRecentEventsAsync();
    _observedPlayerCount = (await StatsApiStreamService.GetObservedPlayersAsync()).Count;
    _dashboardPlayerCount = (await StatsApiStreamService.GetDashboardPlayersAsync()).Count;
    var liveMatch = await StatsApiStreamService.GetLiveMatchStateAsync();
    _connectionDetail = liveMatch is null
      ? "Waiting for UpdateState"
      : $"Updated {liveMatch.UpdatedAt.LocalDateTime:T}";
  }
}
