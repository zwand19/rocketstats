<article class="stat-card">
  <span>@Title</span>
  <strong>@Value</strong>
  @if (!string.IsNullOrWhiteSpace(Detail))
  {
    <small>@Detail</small>
  }
</article>

@code {
  [Parameter]
  public string Title { get; set; } = string.Empty;

  [Parameter]
  public string Value { get; set; } = string.Empty;

  [Parameter]
  public string? Detail { get; set; }
}
